<Window x:Class="Projeto_Senai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Projeto_Senai"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d" 
        d:DesignHeight="1080" d:DesignWidth="1920"
        Title="Dashboard">


    <Grid Background="#F1F5F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#002776">
            <StackPanel>
                <Border Background="White" Height="120" Padding="20">
                    <Image Source="/Images/SENAI_Port_com_assinatura_cor.png" Stretch="Uniform"/>
                </Border>
                <Border Height="5" Background="#EA580C"/>

                <Button Background="#33FFFFFF" Height="70" Foreground="White" BorderThickness="0" Margin="0,30,0,0" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="6" Background="#EA580C" Margin="0,-15,15,-15"/>
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock FontSize="24" FontFamily="/Resources/Roboto/Roboto-Bold.ttf#Roboto" VerticalAlignment="Center">Visão Geral</TextBlock>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Height="120" BorderBrush="#EA580C" BorderThickness="0,0,0,4" Padding="0,0,40,0">
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Height="55" Padding="20,0"
                        Background="Transparent" Foreground="#002776" BorderThickness="3" BorderBrush="#002776"
                        Style="{StaticResource MaterialDesignFlatButton}" Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountLock" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock FontSize="22" FontFamily="/Resources/Roboto/Roboto-Bold.ttf#Roboto" VerticalAlignment="Center">Acesso Administrativo</TextBlock>
                    </StackPanel>
                </Button>
            </Border>

            <StackPanel Grid.Row="1" Margin="60,40,60,20">
                <TextBlock FontFamily="/Resources/Roboto/Roboto-Bold.ttf#Roboto" FontSize="50" Foreground="#002776">Gestão de Ambientes</TextBlock>

                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,25,0,0" BorderBrush="#D1D5DB" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterVariant" Width="35" Height="35" VerticalAlignment="Center" Foreground="#002776" Margin="0,0,15,0"/>
                        <ComboBox x:Name="ComboFiltro" materialDesign:HintAssist.Hint="Pesquisar / Filtrar Ambiente" Width="500" FontSize="20" Foreground="#002776" BorderBrush="#002776" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="ComboFiltro_SelectionChanged">
                            <ComboBoxItem Content="Todos" IsSelected="True"/>
                            <ComboBoxItem Content="Disponíveis"/>
                            <ComboBoxItem Content="Em Uso"/>
                            <ComboBoxItem Content="Manutenção"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="60,10,60,30">
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">
                    <Ellipse Width="18" Height="18" Fill="#16a34a"/>
                    <TextBlock Text="Todos disponíveis" Margin="10,0,0,0" FontSize="18" Foreground="#64748b" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">
                    <Ellipse Width="18" Height="18" Fill="#ea580c"/>
                    <TextBlock Text="Parcialmente ocupado" Margin="10,0,0,0" FontSize="18" Foreground="#64748b" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">
                    <Ellipse Width="18" Height="18" Fill="#dc2626"/>
                    <TextBlock Text="Todos emprestados" Margin="10,0,0,0" FontSize="18" Foreground="#64748b" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="18" Height="18" Fill="#94a3b8"/>
                    <TextBlock Text="Indisponível / Aguardando" Margin="10,0,0,0" FontSize="18" Foreground="#64748b" FontWeight="Medium"/>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="3" Margin="60,0,60,20" VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="icAmbientes">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Height="160" Margin="0,0,25,25" CornerRadius="12" Background="{Binding CorStatus}" Cursor="Hand">
                                <Grid>
                                    <TextBlock Text="{Binding Nome}" FontSize="24" FontWeight="Bold" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               TextWrapping="Wrap" TextAlignment="Center" Margin="15"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
